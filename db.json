":"280dae3fd38086158b4a1b57edb94c06b1a5014b","modified":1659667026044},{"_id":"public/img/zhihu.png","hash":"a6d6ef65e9ac82e613a311810391ebb90d9b1c1d","modified":1659667026044},{"_id":"public/css/fonts/fontawesome-webfont.eot","hash":"3ce87b82c7a4ffdf65e96765c2ffda10b1a283c6","modified":1659667026044},{"_id":"public/css/fonts/fontawesome-webfont.svgz","hash":"4bfdd33ed702e32ae01399fcc2652377f78e7626","modified":1659667026044},{"_id":"public/css/fonts/fontawesome-webfont.ttf","hash":"1480b8101b02da9bc4c60341b5e185e63e585064","modified":1659667026044},{"_id":"public/css/fonts/fontawesome-webfont.woff","hash":"cafc4ac5761a0a252d33dce4ea3952cf9a38d832","modified":1659667026044},{"_id":"public/fancybox/helpers/fancybox_buttons.png","hash":"e385b139516c6813dcd64b8fc431c364ceafe5f3","modified":1659667026044},{"_id":"public/css/fonts/fontawesome-webfont.svg","hash":"23a6f5b2ff76de9cb3cf1e886194c67647fd868a","modified":1659667026044},{"_id":"public/fancybox/jquery.fancybox.css","hash":"0fb36984d6889187b1af02bf1968931a1623528a","modified":1659667026044},{"_id":"public/js/Counter.js","hash":"6697d5dfba2700c059722b62d856d4c86c73031a","modified":1659667026044},{"_id":"public/js/instagram.js","hash":"f19adbcc0dac33536bc6660598059048ec901882","modified":1659667026044},{"_id":"public/js/jquery.lazyload.js","hash":"c11a2e7b330d16d06feabd0a8477099adf9d6799","modified":1659667026044},{"_id":"public/js/main.js","hash":"5e92a3694111e5ae5aca37c79157218d35f2e63b","modified":1659667026044},{"_id":"public/js/mobile.js","hash":"b68cc01d24e80973c48205f551da87f3f3427644","modified":1659667026044},{"_id":"public/js/pc.js","hash":"5520f663c8f2ac94b2ff277f235bb52fc91cc28f","modified":1659667026044},{"_id":"public/fancybox/helpers/jquery.fancybox-buttons.css","hash":"1a9d8e5c22b371fcc69d4dbbb823d9c39f04c0c8","modified":1659667026044},{"_id":"public/fancybox/helpers/jquery.fancybox-buttons.js","hash":"dc3645529a4bf72983a39fa34c1eb9146e082019","modified":1659667026044},{"_id":"public/fancybox/helpers/jquery.fancybox-media.js","hash":"294420f9ff20f4e3584d212b0c262a00a96ecdb3","modified":1659667026044},{"_id":"public/fancybox/helpers/jquery.fancybox-thumbs.css","hash":"4ac329c16a5277592fc12a37cca3d72ca4ec292f","modified":1659667026044},{"_id":"public/fancybox/helpers/jquery.fancybox-thumbs.js","hash":"47da1ae5401c24b5c17cc18e2730780f5c1a7a0c","modified":1659667026044},{"_id":"public/css/style.css","hash":"abf64e04a378504071cd2a3b0a61ef868c294aa4","modified":1659667026044},{"_id":"public/fancybox/jquery.fancybox.js","hash":"a82597493d75ea989ca586e09173cff332efe41e","modified":1659667026044},{"_id":"public/fancybox/jquery.fancybox.pack.js","hash":"9e0d51ca1dbe66f6c0c7aefd552dc8122e694a6e","modified":1659667026044},{"_id":"public/js/particles.js","hash":"c4286268c2071a624bf3c8565f6328eccecacf30","modified":1659667026044},{"_id":"source/git-command/index.md","hash":"3372ab741ea9820da3c5194f89e258643c39d399","modified":1659688118455},{"_id":"public/git-command/index.html","hash":"1251aa1d7c5bd02141cd00e2e48b28370040d7a8","modified":1659688127256},{"_id":"source/_posts/git.md","hash":"51e7fe5db2c89537c41d0fdab65d22656261d79d","modified":1659688239811},{"_id":"public/2022/08/05/git/index.html","hash":"a82d01144b6b5128147c0470eb998a97231ed161","modified":1659688951907},{"_id":"source/_posts/git-command.md","hash":"f62756c39a88785fd642e95b783aae84ea44cb38","modified":1659689566957},{"_id":"public/2022/08/05/git-command/index.html","hash":"0b3dedb8f14054c7be3ffa54e006eabe475e6329","modified":1659689839772},{"_id":"public/tags/git/index.html","hash":"439c0341505faa192ff7c3e267791573e3b92cc0","modified":1659689232622},{"_id":"source/_posts/test.md","hash":"0c1a4558b12fc060f2e4c8f7472918df0e00a84c","modified":1659689833022},{"_id":"public/2022/08/05/test/index.html","hash":"9deb2da1fde12fa4b186ee97a1decb5955af5e8c","modified":1659689839772}],"Category":[],"Data":[],"Page":[],"Post":[{"title":"git command","date":"2022-08-05T08:44:02.000Z","_content":"\n\n**全局配置**\n\n```bash\n$ git config --global user.name \"Name\"\n$ git config --global user.email \"**.com\"\n$ git config --list\n```\n\n**局部仓库配置**\n\n```bash\n$ git config  user.name \"Name\"\n$ git config  user.email \"**.com\"\n$ git config --list\n```\n\n**常用指令**\n\n- basic command \n\n  ```bash\n    $ git add\n    $ git commit\n    $ git push\n    ```\n\n- 查看日志\n\n  ```bash\n  $ git log --pretty=oneline \n  $ git log --oneline\n  $ git reflog\n  ```\n\n- 版本控制\n\n  ```bash\n  $ git reset --hard index\n  $ git reset --hard head^^\n  $ git reset --hard head~2\n  ```\n\n- 分支\n\n  ```bash\n  $ git branch -v\n  $ git checkout branchName\n  $ git branch branchName\n  ```\n\n  - 合并\n\n    ```bash\n    $ git chekout branchName\n    $ git merge branchName\n    ```\n\n- 远程push源设置\n\n  ```bash\n  $ git remote -v\n  $ git remote add origin https:......\n  $ gite push origin branchName\n  ```\n\n- 克隆拉取\n\n  ```bash\n  $ git clone htpps:.....\n  pull = fetch + merge\n  $ git fetch origin/branchName\n  ```\n","source":"_posts/git-command.md","raw":"---\ntitle: git command\ndate: 2022-08-05 16:44:02\ntags: \n  - git\n---\n\n\n**全局配置**\n\n```bash\n$ git config --global user.name \"Name\"\n$ git config --global user.email \"**.com\"\n$ git config --list\n```\n\n**局部仓库配置**\n\n```bash\n$ git config  user.name \"Name\"\n$ git config  user.email \"**.com\"\n$ git config --list\n```\n\n**常用指令**\n\n- basic command \n\n  ```bash\n    $ git add\n    $ git commit\n    $ git push\n    ```\n\n- 查看日志\n\n  ```bash\n  $ git log --pretty=oneline \n  $ git log --oneline\n  $ git reflog\n  ```\n\n- 版本控制\n\n  ```bash\n  $ git reset --hard index\n  $ git reset --hard head^^\n  $ git reset --hard head~2\n  ```\n\n- 分支\n\n  ```bash\n  $ git branch -v\n  $ git checkout branchName\n  $ git branch branchName\n  ```\n\n  - 合并\n\n    ```bash\n    $ git chekout branchName\n    $ git merge branchName\n    ```\n\n- 远程push源设置\n\n  ```bash\n  $ git remote -v\n  $ git remote add origin https:......\n  $ gite push origin branchName\n  ```\n\n- 克隆拉取\n\n  ```bash\n  $ git clone htpps:.....\n  pull = fetch + merge\n  $ git fetch origin/branchName\n  ```\n","slug":"git-command","published":1,"updated":"2022-08-05T08:52:46.957Z","_id":"cl6g8480c0000w2d53tap6azd","comments":1,"layout":"post","photos":[],"link":"","content":"<p><strong>全局配置</strong></p>\n<figure class=\"highlight bash\"><table><tr><td class=\"gutter\"><pre><span class=\"line\">1</span><br><span class=\"line\">2</span><br><span class=\"line\">3</span><br></pre></td><td class=\"code\"><pre><span class=\"line\">$ git config --global user.name <span class=\"string\">&quot;Name&quot;</span></span><br><span class=\"line\">$ git config --global user.email <span class=\"string\">&quot;**.com&quot;</span></span><br><span class=\"line\">$ git config --list</span><br></pre></td></tr></table></figure>\n\n<p><strong>局部仓库配置</strong></p>\n<figure class=\"highlight bash\"><table><tr><td class=\"gutter\"><pre><span class=\"line\">1</span><br><span class=\"line\">2</span><br><span class=\"line\">3</span><br></pre></td><td class=\"code\"><pre><span class=\"line\">$ git config  user.name <span class=\"string\">&quot;Name&quot;</span></span><br><span class=\"line\">$ git config  user.email <span class=\"string\">&quot;**.com&quot;</span></span><br><span class=\"line\">$ git config --list</span><br></pre></td></tr></table></figure>\n\n<p><strong>常用指令</strong></p>\n<ul>\n<li><p>basic command </p>\n<figure class=\"highlight bash\"><table><tr><td class=\"gutter\"><pre><span class=\"line\">1</span><br><span class=\"line\">2</span><br><span class=\"line\">3</span><br></pre></td><td class=\"code\"><pre><span class=\"line\">$ git add</span><br><span class=\"line\">$ git commit</span><br><span class=\"line\">$ git push</span><br></pre></td></tr></table></figure>\n</li>\n<li><p>查看日志</p>\n<figure class=\"highlight bash\"><table><tr><td class=\"gutter\"><pre><span class=\"line\">1</span><br><span class=\"line\">2</span><br><span class=\"line\">3</span><br></pre></td><td class=\"code\"><pre><span class=\"line\">$ git <span class=\"built_in\">log</span> --pretty=oneline </span><br><span class=\"line\">$ git <span class=\"built_in\">log</span> --oneline</span><br><span class=\"line\">$ git reflog</span><br></pre></td></tr></table></figure>\n</li>\n<li><p>版本控制</p>\n<figure class=\"highlight bash\"><table><tr><td class=\"gutter\"><pre><span class=\"line\">1</span><br><span class=\"line\">2</span><br><span class=\"line\">3</span><br></pre></td><td class=\"code\"><pre><span class=\"line\">$ git reset --hard index</span><br><span class=\"line\">$ git reset --hard <span class=\"built_in\">head</span>^^</span><br><span class=\"line\">$ git reset --hard <span class=\"built_in\">head</span>~2</span><br></pre></td></tr></table></figure>\n</li>\n<li><p>分支</p>\n<figure class=\"highlight bash\"><table><tr><td class=\"gutter\"><pre><span class=\"line\">1</span><br><span class=\"line\">2</span><br><span class=\"line\">3</span><br></pre></td><td class=\"code\"><pre><span class=\"line\">$ git branch -v</span><br><span class=\"line\">$ git checkout branchName</span><br><span class=\"line\">$ git branch branchName</span><br></pre></td></tr></table></figure>\n\n<ul>\n<li><p>合并</p>\n<figure class=\"highlight bash\"><table><tr><td class=\"gutter\"><pre><span class=\"line\">1</span><br><span class=\"line\">2</span><br></pre></td><td class=\"code\"><pre><span class=\"line\">$ git chekout branchName</span><br><span class=\"line\">$ git merge branchName</span><br></pre></td></tr></table></figure></li>\n</ul>\n</li>\n<li><p>远程push源设置</p>\n<figure class=\"highlight bash\"><table><tr><td class=\"gutter\"><pre><span class=\"line\">1</span><br><span class=\"line\">2</span><br><span class=\"line\">3</span><br></pre></td><td class=\"code\"><pre><span class=\"line\">$ git remote -v</span><br><span class=\"line\">$ git remote add origin https:......</span><br><span class=\"line\">$ gite push origin branchName</span><br></pre></td></tr></table></figure>\n</li>\n<li